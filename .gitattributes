# Normalize line endings
* text=auto

# Markdown
*.md text eol=lf

# JSON / YAML / lock files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
pnpm-lock.yaml text eol=lf -diff

# Vue / JS / TS
*.vue text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Images – treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
